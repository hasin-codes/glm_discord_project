
# ===========================================
# PRODUCTION .gitignore - Discord Bot v6.9
# ===========================================

# Dependencies
node_modules/
# package-lock.json - NOW COMMITTED FOR RAILWAY

# Environment
.env

# Logs
*.log
.test-results.txt
# Supabase
supabase/.temp/
supabase/.env

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local

# Build outputs
dist/
build/

# ===========================================
# TEST FILES (Exclude from production)
# ===========================================

# Unit tests
__tests__/

# Test runner scripts (manual testing only)
test-*.js
*_test.js

# ===========================================
# DOCUMENTATION (Keep essential, exclude dev docs)
# ===========================================

# Keep README (needed for deployment)
!README.md

# Exclude internal dev docs
docs/
prd.md
layer.md
full.md
l.md

# Keep production docs
!m.md
!DEPLOYMENT_CHECKLIST.md
!PRODUCTION_FILES.md
!RAILWAY_DEPLOY.md

# ===========================================
# IDE & EDITOR FILES
# ===========================================

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.iml
*.ipr
*.iws
.qwen/

# ===========================================
# LOGS & RUNTIME DATA
# ===========================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

pids/
*.pid
*.seed
*.pid.lock

# ===========================================
# TEMPORARY FILES
# ===========================================

tmp/
temp/
.tmp/
.temp/

# ===========================================
# LOCAL DEVELOPMENT DATA
# ===========================================

# Qdrant local
.qdrant/
qdrant_storage/

# Redis local
dump.rdb

# Supabase local
.supabase/

# Virtual environments
venv/
env/
ENV/

# ===========================================
# CACHE FILES
# ===========================================

.npm
.eslintcache
*.tsbuildinfo
.node_repl_history

# ===========================================
# PACKAGE MANAGER
# ===========================================

# Yarn
.yarn-integrity
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Output of 'npm pack'
*.tgz

# ===========================================
# DEPLOYMENT CONFIG (Railway specific)
# ===========================================

.railway/

# Keep these for Railway deployment
railway.toml
nixpacks.toml

# ===========================================
# OS SPECIFIC
# ===========================================

Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
