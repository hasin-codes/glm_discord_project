
# ===========================================
# PRODUCTION .gitignore - Discord Bot v6.9
# ===========================================

# Dependencies
node_modules/
package-lock.json

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local

# Build outputs
dist/
build/

# ===========================================
# TEST FILES (Exclude from production)
# ===========================================

# Unit tests
__tests__/

# Pipeline tests
pipeline/tests/

# Test runner scripts
test4-runner.js

# Test output files
*.test.js
*.spec.js
coverage/
.nyc_output/

# ===========================================
# DEVELOPMENT & DEBUG SCRIPTS
# ===========================================

# Debug scripts
_debug.js
debug_*.js

# Manual test scripts (not needed in production)
test-*.js
*_test.js

# Test data generation
test-pipeline-report.js
test-pipeline-real-data.js
test-last-2000.js

# One-shot scripts (run manually, not in production)
scripts/runCleaning.js
scripts/runRetentionCleanup.js
scripts/seedMessages.js
scripts/ingest.js

# ===========================================
# DOCUMENTATION (Keep essential, exclude dev docs)
# ===========================================

# Keep README (needed for deployment)
!README.md

# Exclude internal dev docs
docs/
prd.md
layer.md
full.md
l.md

# Keep production docs
!m.md
!DEPLOYMENT_CHECKLIST.md
!PRODUCTION_FILES.md
!RAILWAY_DEPLOY.md

# Generated reports (from test runs)
cluster-report.md
report.md
*-report.md

# ===========================================
# IDE & EDITOR FILES
# ===========================================

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.iml
*.ipr
*.iws
.qwen/

# ===========================================
# LOGS & RUNTIME DATA
# ===========================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

pids/
*.pid
*.seed
*.pid.lock

# ===========================================
# TEMPORARY FILES
# ===========================================

tmp/
temp/
.tmp/
.temp/

# ===========================================
# LOCAL DEVELOPMENT DATA
# ===========================================

# Qdrant local
.qdrant/
qdrant_storage/

# Redis local
dump.rdb

# Supabase local
.supabase/

# Python cache (for HDBSCAN)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pipeline/scripts/*.pyc

# Virtual environments
venv/
env/
ENV/

# ===========================================
# CACHE FILES
# ===========================================

.npm
.eslintcache
*.tsbuildinfo
.node_repl_history

# ===========================================
# PACKAGE MANAGER
# ===========================================

# Yarn
.yarn-integrity
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Output of 'npm pack'
*.tgz

# ===========================================
# DEPLOYMENT CONFIG (Railway specific)
# ===========================================

.railway/

# Keep these for Railway deployment
railway.toml
nixpacks.toml

# ===========================================
# OS SPECIFIC
# ===========================================

Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
